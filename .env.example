# 数据库：默认 SQLite。如要使用 MySQL，将 DB_DRIVER 改为 mysql 并填写 DSN
DB_DRIVER=sqlite
DB_DSN=./data/storage/papers.db
# MySQL 示例:
# DB_DRIVER=mysql
# DB_DSN=user:pass@tcp(127.0.0.1:3306)/papers?parseTime=true&charset=utf8mb4

# Python 侧车（嵌入 / LLM / 分析）
PY_SERVICE_URL=http://127.0.0.1:8001

# 大模型（OpenAI 兼容协议）。默认走火山方舟（Volces Ark）的 DeepSeek 部署。
# scripts/dev.sh 与 scripts/ingest.sh 里也硬编码了同一组默认值，环境变量优先级最高。
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=602ff18b-1166-4e51-bb42-82d9556d47f8
LLM_MODEL=deepseek-v3-2-251201
LLM_TEMPERATURE=0.2

# 嵌入模型：本地 SentenceTransformer 模型名或 OpenAI 嵌入名（火山方舟暂无兼容 embeddings 接口）
EMBED_BACKEND=local
EMBED_MODEL=BAAI/bge-small-zh-v1.5

# 后端监听
API_ADDR=:8080
CORS_ORIGIN=http://localhost:5173
